# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# JWT Configuration
JWT_SECRET="your-jwt-secret-key"
JWT_EXPIRES_IN="7d"

# OneDrive Configuration (Microsoft Graph API)
ONEDRIVE_CLIENT_ID="your-microsoft-app-client-id"
ONEDRIVE_CLIENT_SECRET="your-microsoft-app-client-secret"
ONEDRIVE_TENANT_ID="your-microsoft-tenant-id"
ONEDRIVE_REFRESH_TOKEN="your-onedrive-refresh-token"
ONEDRIVE_REDIRECT_URI="http://localhost:8000/auth/onedrive/callback"

# Server Configuration
PORT=8000
NODE_ENV="development"
